    },
    "m_SourceType": 1,
    "m_FunctionName": "GetWaveHeight",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float heightX = sin((position.x + (time * waveSpeed.x)) * waveFreq.x);\r\nfloat heightZ = sin((position.z + (time * waveSpeed.y)) * waveFreq.y);\r\nheight = ((heightX + heightZ) / 2.0f) * waveHeightMult;"
}

